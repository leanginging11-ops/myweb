    $scope.onChangeProvince = function (province, dis_list_name, com_list_name, vil_list_name, filter_by_code=true){   
        if(filter_by_code){ 
            $scope[dis_list_name] = [];
            get_districts_list_by_province(province, dis_list_name);
            // $scope[dis_list_name] = districts['data'].filter(val => val.province_code == province);  
        } 
        $scope[com_list_name] = [];
        $scope[vil_list_name] = []; 
        if(dis_list_name == "birth_districts_list"){
            $scope.birth_district = ""; 
            $scope.birth_commune = ""; 
            $scope.birth_village = ""; 
        }else if(dis_list_name == "current_districts_list"){ 
            $scope.current_district = "";  
            $scope.current_commune = ""; 
            $scope.current_village = ""; 
        }
    }

    $scope.onChangeDistrict = function (district, com_list_name, vil_list_name, filter_by_code=true){  
        $scope[com_list_name] = [];
        if(filter_by_code){
            // $scope[com_list_name] = communes['data'].filter(val => val.district_code == district); 
            get_communes_list_by_district(district, com_list_name);
        }

        $scope[vil_list_name] = []; 
        if(com_list_name == "birth_communes_list"){
            $scope.birth_commune = ""; 
            $scope.birth_village = ""; 
        }else if(com_list_name == "current_communes_list"){  
            $scope.current_commune = ""; 
            $scope.current_village = ""; 
        }
    }


    $scope.onChangeCommune = function (commune, vil_list_name, filter_by_code=true){  
        $scope[vil_list_name] = [];
        if(filter_by_code){
            get_villages_list_by_commune(commune, vil_list_name);
            // $scope[vil_list_name] = villages['data'].filter(val => val.commune_code == commune); 
        } 
        if(vil_list_name == "birth_villages_list"){
            $scope.birth_village = ""; 
        }else if(vil_list_name == "current_villages_list"){ 
            $scope.current_village = ""; 
        } 
    }

    // get membership id onchange
    $scope.onChangeMembershipType = function (membership_type){
        var item = $scope.register.member_type_list.filter( obj => obj.member_type == membership_type);   
        $scope.registerData.membership_id = item? item[0]['id'] : null; 
        $scope.registerData.annual_contribution = item[0]['annual_contribution'];
    }

    // correct format Phone Number
    $scope.formatPhoneNumber = function (attr_name1, attr_name2){   
        if($scope[attr_name1][attr_name2]){
            var phone_number = $scope[attr_name1][attr_name2].replace(/\s/g,'');
            if(phone_number.length >= 9){ 
                var h_number = phone_number.trim().substring(0,3); 
                var b_number = phone_number.trim().substring(3);   
                $scope[attr_name1][attr_name2] = h_number + " " + b_number;
            }
        }
    }
    
    function get_districts_list_by_province(code, list_name){  
        var query_function = "get_districts"; 
        var form_action = "get_administrative_location";  
        var form_data_obj = {
            'lang' : 'all',
            'province_code' : code,  
            'district_code' : '',
            'function'  : query_function,
        }
 
        call_ajax_get_administrative_data(form_action, form_data_obj, list_name); 
    } 
    
    function get_communes_list_by_district(code, list_name){  
        var query_function = "get_communes"; 
        var form_action = "get_administrative_location";  
        var form_data_obj = {
            'lang' : 'all', 
            'district_code' : code,
            'commune_code' : '',  
            'function'  : query_function,
        }
        // console.log(form_data_obj);
        call_ajax_get_administrative_data(form_action, form_data_obj, list_name); 
    }

    function get_villages_list_by_commune(code, list_name){  
        var query_function = "get_villages"; 
        var form_action = "get_administrative_location";  
        var form_data_obj = {
            'lang' : 'all', 
            'commune_code' : code,
            'village_code' : '',  
            'function'  : query_function,
        }
 
        call_ajax_get_administrative_data(form_action, form_data_obj, list_name); 
    }

    /*
    * resetForm
    */
    $scope.resetForm = function(formName, ngModel) {
        $scope[ngModel] = {};
        $scope[formName].$setPristine(); 
        $scope[formName].$setUntouched();   
        //reset recaptcha
        grecaptcha.reset();
    };

    // Uploader
    /**
     * open File dialogue
     */
    $scope.openFileDialogue = function(){
        $scope.is_openingFileDialogue = true;
        $scope.register.is_uploadingImage = false;
        $timeout(function(){
            $scope.is_openingFileDialogue = false; 
        }, 1700);
    }

    /**
     * watch if photo is upload
     */
    $scope.$watch('photo_files', function () { 
        if($scope.photo_files){ 
            $scope.uploadPhoto($scope.photo_files);
        }
    }); 
    /**
     * Upload File
     */
    $scope.uploadPhoto = function (files) {  
        if(!files){
            return;
        }else if(files.length){ 
            var form_data_obj = new FormData();
            form_data_obj.append("file", files[0]);
            var file = files[0]; //single file
            var form_action = 'process_upload_single_file';    
            Upload.upload({
                    url: CYN_PLUGIN_NAME +'/utils/upload.php',
                    // url: cyn_wp_ajax.ajax_url +'?action=' + form_action, 
                    // url: CYN_PLUGIN_NAME +'/includes/class-upload.php',
                    file: file,
                    name: file.name
                }).progress(function (evt) { 
                    $scope.is_openingFileDialogue = true;
                    console.log("proecess uploading");
                    // var progressPercentage = parseInt(100.0 * evt.loaded / evt.total);
                    // $scope.log = 'progress: ' + progressPercentage + '% ' +
                    //             evt.config.file.name + '\n' + $scope.log; 
                }).success(function (data, status, headers, config) {
                    $timeout(function() { 
                        if(data){ 
                            $scope.register.is_uploaded_photo = true; 
                            // $scope.register.is_uploadingImage = false;
                            $scope.register.photo = data.url; 
                            $scope.registerData.photo = data.url; 
                        }

                        $scope.is_openingFileDialogue = false;
                    }, 200);
                });  
        } 
    };
    
    $scope.removePhoto = function(){
        $scope.register.is_uploaded_photo = false; 
        $scope.registerData.photo = ''; 
    }

    
    $scope.$watch('dob', function(){
        if($scope.dob){ 
