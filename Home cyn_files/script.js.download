    function showDialogInfo ($event, title, text, min_width='400px') {
        var parentEl = angular.element(document.body);
        $mdDialog.show({
          parent: parentEl,
          targetEvent: $event,
          template:
            '<md-dialog aria-label="List dialog">' +
            '  <md-dialog-content style="min-width:'+ min_width +'">'+
            '    <h4 class="headline-'+title+'">'+ title + '</h4>'+
            '    <div class="content-dialog">'+
            '       <p>'+ text +'</p>' + 
            '    </div>'+ 
            '  </md-dialog-content>' +
            '  <md-dialog-actions>' +
            '    <md-button ng-click="ctrl.closeDialog()" class="md-primary">' +
            '      Close' +
            '    </md-button>' +
            '  </md-dialog-actions>' +
            '</md-dialog>', 
          controller: DialogController,
          controllerAs: 'ctrl'
       });
       function DialogController($mdDialog) {
         this.closeDialog = function() {
           $mdDialog.hide();
         }
       }
    }
   
    // Show Edit Dialog
    function showEditDialog($event, title, min_width='400px', call_function, item) {
        var parentEl = angular.element(document.body);
        $mdDialog.show({
            parent: parentEl,
            targetEvent: $event,
            locals:{dataItem: item}, 
            clickOutsideToClose: true,
            template:
                '<md-dialog aria-label="List dialog">' + 
                    '  <md-dialog-content style="min-width:'+ min_width +'">'+
                    '   <h3 class="headline-'+title+' m-15 m-b-0">'+ title + '</h3>'+
                    '   <div class="content-dialog border-ccc m-15 p-15">'+   
                    '       <div class="row-cols m-t-10 p-0">'+ 
                    '           <div class="cols col-5 p-0">'+ 
                    '           <md-input-container class="md-container w-90p p-0 m-0">'+
                    '               <label class="m-0 m-l-10 lh-22 font-14 font-normal">English Name</label>'+    
                    '               <input type="text" ng-model="item.english_name" name="name_en">'+
                    '               <div ng-if="editItem.is_nameEnEmpty" class="text-red m-t-5">Please Add Name in English</div>'+
                    '           </md-input-container>'+
                    '           </div>'+ 

                    '           <div class="cols col-5 p-0">'+ 
                    '           <md-input-container class="md-container w-90p p-0 m-0">'+
                    '               <label class="m-0 m-l-10 lh-22 font-14 font-normal">English Khmer</label>'+    
                    '               <input type="text" ng-model="item.khmer_name" name="name_km">'+
                    '               <div ng-if="editItem.is_nameKhEmpty" class="text-red m-t-5">Please Add Name in Khmer</div>'+
                    '           </md-input-container>'+
                    '           </div>'+ 
                    '       </div>'+ 
                    '       <div class="row-cols p-0">'+  
                    '           <div class="cols col-5 p-0">'+ 
                    '           <md-input-container class="md-container w-90p p-0 m-0">'+
                    '               <label class="m-0 m-l-10 lh-22 font-14 font-normal">Nationality</label>'+    
                    '               <input type="text" ng-model="item.nationality" name="nationality">'+
                    '               <div ng-if="editItem.is_nationalityEmpty" class="text-red m-t-5">Please Add Nationality</div>'+
                    '           </md-input-container>'+
                    '           </div>'+  

                    '           <div class="cols col-5 p-0">'+ 
                    '           <md-input-container class="md-container w-90p p-0 m-0">'+
                    '               <label class="m-0 m-l-10 lh-22 font-14 font-normal">Gender</label>'+    
                    '               <input type="text" ng-model="item.gender" name="gender">'+
                    '               <div ng-if="editItem.is_genderEmpty" class="text-red m-t-5">Please Add Gender</div>'+
                    '           </md-input-container>'+
                    '           </div>'+  
                    '       </div>'+ 
                    '       <div class="row-cols p-0">'+  
                    '           <div class="col-6 p-0">'+  
                    '           <md-input-container class="md-container w-90p p-0 m-0">'+
                    '               <md-datepicker ng-model="item.date_of_birth" ng-change="datepickerChange(date_of_birth)"></md-datepicker>'+
                    '               <input type="hidden" value="{{item.date_of_birth| amDateFormat:\'YYYY-MM-DD\'}}" name="date_of_birth" required>'+             
                    '           </md-input-container>'+ 
                    '           </div>'+ 
                    '       </div>'+  
                    '    </div>'+  
                    '  </md-dialog-content>' +
                        '<md-dialog-actions>' +
                            '    <md-button ng-click="ctrlUpdate.update()" class="md-primary">' +
                            '      Update' +
                            '    </md-button>' +
                            '    <md-button ng-click="ctrlUpdate.closeDialog()" class="md-accent">' +
                            '      Close' +
                            '    </md-button>' +
                        '</md-dialog-actions>' +
                '</md-dialog>', 
                controller: function DialogControllerUpdate ($scope, $mdDialog, dataItem) { 
                    $scope.editItem = Object.assign({}, dataItem);
                    $scope.editItem.display_public = dataItem.display_public? true : false;

                    this.update = function() { 
                        call_function($scope.editItem);
                        $mdDialog.hide();
                    }
    
                    this.closeDialog = function() {
                        $mdDialog.hide();
                    }
            },
            controllerAs: 'ctrlUpdate'
        }); 
    }
    
    
