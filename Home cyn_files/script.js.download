    });
 
    $scope.test_recaptcha = function(){ 
        var form_data = jQuery('#registerForm').serializeArray() ; 
        var form_data_obj = {};
        $scope.is_loading = true;
        jQuery(form_data ).each(function(index, obj){
            form_data_obj[obj.name] = obj.value;
        }); 
        console.log(form_data_obj['g-recaptcha-response']);
    }

    /**
     * Submit Setting Form
     */
    $scope.submitRegestration = function(event, form){
        $scope.defaultErrorMessage();  
        // event.preventDefault();     
        // if(form.$valid) { } 
        if($scope.registerData.password != $scope.registerData.confirm_password ){
            $scope.register.is_confirmPasswordIncorrect = true;
            console.log("confirm Password is Incorrect");
            return;
        }  
        if(!$scope.registerData.family_status){
            $scope.register.is_family_status_empty = true;
            console.log("family status is empty");
            return;
        }  
        if(!$scope.registerData.membership_type){
            $scope.register.is_membership_type_empty = true;
            console.log("membership type is empty");
            return;
        } 
        if(!$scope.registerData.annual_contribution){
            $scope.register.is_annual_contribution_empty = true;
            console.log("annual contribution is empty");
            return;
        } 
        var form_action = "process_new_member_register";
        var query_function = null; //"new_registration";  
        var output_function = "clearInsertForm";
         
        var form_data = jQuery('#registerForm').serializeArray() ; 
        // var form_data = jQuery('#registerForm').serialize() ;  
        var form_data_obj = {}; 
        jQuery(form_data ).each(function(index, obj){ 
            // if form contains multiple array
            var splite_name = obj.name.replace(/]/g, '').split('['); //0: "education", 1: "1", 2: "education_level"

            if(splite_name.length == 1){  
                form_data_obj[obj.name] = obj.value; 
            }else if(splite_name.length == 2){ // create obj
                var k0 = splite_name[0]; 
                var k1 = splite_name[1];
                if(!form_data_obj[k0]){
                    form_data_obj[k0] = {}
                } 
                form_data_obj[k0][k1] = obj.value;
            }else if(splite_name.length == 3){ // create array obj
                var k0 = splite_name[0];
                var k1 = parseInt(splite_name[1])-1;
                var k2 = splite_name[2];
                if(!form_data_obj[k0]){
                    form_data_obj[k0] = [];
                }

                if (!form_data_obj[k0][k1]) {
                    form_data_obj[k0][k1] = {};
                } 
                form_data_obj[k0][k1][k2] = obj.value; 
            }else{  
                form_data_obj[obj.name] = obj.value;
            }
        });  
  
        if(!form_data_obj['g-recaptcha-response']){
            $scope.register.is_recaptcha_empty = true;
            return;
        } 

        var index = $scope.register.member_type_list.findIndex(function(element) { 
            return element.member_type == form_data_obj['membership_type'];
        });
        form_data_obj['membership_id'] = $scope.register.member_type_list[index].id; 
        

        $scope.is_loading = true;
        $scope.register.is_processing = true; 
        // console.log(form_data_obj); 
        // console.log(JSON.stringify(form_data_obj));
        var form_data_obj_json = JSON.stringify(form_data_obj);
        call_ajax_insert_data(form_action, form_data_obj_json, query_function, output_function); 
    } 
    
    /**
     * Update Profile Form
     */
    $scope.updateProfile = function(event, form){
        $scope.defaultErrorMessage();   
        $scope.register.is_processing = true; 
        var form_action = "process_update_profile";
        var query_function = null; // "update_profile_user";  
        var output_function = refreshUserProfile; //"clearInsertForm";
            
        var form_data = jQuery('#updateProfileForm').serializeArray() ; 
        var form_data_obj = {};
        jQuery(form_data ).each(function(index, obj){
            form_data_obj[obj.name] = obj.value;
        }); 
        console.log(form_data_obj);
        call_ajax_update_data(form_action, form_data_obj, query_function, output_function); 
    } 

    function refreshUserProfile(){ 
        $timeout(function(){  
            var url= document.location.href; 
            window.location = url;
        }, 100);
    }

    /**
     * Login Form
     */
     $scope.memberLogin = function(event, form){ 
        $scope.defaultErrorMessage();   
        if(!$scope.loginData.user_account){
            $scope.login.is_user_account_empty = true;  
            return;
        }   
        if(!$scope.loginData.password){
            $scope.login.is_password_empty = true;
            return;
        }  

        var form_action = "process_member_login";
        var query_function = "member_login";  
        var output_function = "clearLoginForm";
        var loading_element = 'login';
         
        var form_data = jQuery('#loginForm').serializeArray() ; 
        var form_data_obj = {};
        jQuery(form_data ).each(function(index, obj){
            form_data_obj[obj.name] = obj.value;
        });  

        call_ajax_get_data(form_action, form_data_obj, query_function, output_function, loading_element); 
    } 

    $scope.memberForgetPassword = function(event, form){ 
        $scope.defaultMessageForgetPassword();
        if(!$scope.forgetData.username_email){
            $scope.forget.is_user_email_empty = true;
            return;
        }

        var form_action = "process_forget_reset_email";
        var query_function = "forget_reset_email";  
        var output_function = "clearForgetForm";
        var loading_element = 'forget';
         
        var form_data = jQuery('#forgetForm').serializeArray() ; 
        var form_data_obj = {};
        jQuery(form_data ).each(function(index, obj){
            form_data_obj[obj.name] = obj.value;
        });  

        call_ajax_get_data(form_action, form_data_obj, query_function, output_function, loading_element); 

    }

    /**
     * Clear Insert Form and call updated list
     */
    $scope.clearInsertForm = function(){ 
        $scope.resetForm('formRegister', 'registerData');  
        $scope.register.is_processing = false; 
        $scope.is_loading = false;  
        $scope.is_openingFileDialogue = false; 
    }

    /**
     * Clear Login Form and call updated list
     */
     $scope.clearLoginForm = function(item=null){  
        $scope.loginData.user_account = '';
        $scope.loginData.password = ''; 
        var role = item.role? item.role : item.wp_user.roles? item.wp_user.roles[0] : null;
        var member_subscript = ["member", "subscriber"];
        if(member_subscript.includes(item.role)){ 
            window.location = item.profile_page;
        }  
    }     

    /**
     * @param {*} form_action: string
     * @param {*} form_data_obj: string
     * @param {*} callback_function: string
     * @param {*} callback_function_on_close_dialog: string
     */
    function call_ajax_get_administrative_data (form_action, form_data_obj, output_list_name){    
        angular.element.ajax({  
            method      : 'POST',  
            url         : cyn_wp_ajax.ajax_url +'?action=' + form_action, 
            dataType    : 'json', 
            contentType: "application/x-www-form-urlencoded; charset=UTF-8", // $_POST 
            data        : { formData : form_data_obj }, 
            cache       : true, 
            beforeSend:function(){  
            },
            success  : function(respond){   
                // console.log(respond); 
                if(respond.type =='success'){  
                    if(output_list_name){  
                        $scope[output_list_name] = respond.data; 
                        // console.log(output_list_name);
                        // console.log($scope[output_list_name]);
                    }
                }else{
                    console.log("No data");
                }
            },
            error: function (data) {  
                console.log('An error occurred.');
                // var responseTextObject = jQuery.parseJSON(response.responseText);
                console.log(data);
            }
        });
    } 

    /**
     * @param {*} form_action: string
     */
    function call_ajax_get_data (form_action, form_data_obj, query_function, output_function, loading_element=null){   
        form_data_obj.function =  query_function; 
        angular.element.ajax({  
            method      : 'POST',  
            url         : cyn_wp_ajax.ajax_url +'?action=' + form_action, 
            dataType    : 'json', 
            contentType : "application/x-www-form-urlencoded; charset=UTF-8", // $_POST 
            data        : { formData : form_data_obj }, 
            cache       : false, 
            beforeSend:function(){ 
                $scope[loading_element].is_processing = true;
            },
            success  : function(respond){ 
                console.log(respond);
                if(respond.length){ 
                    if(output_function){
                        $scope[output_function](respond);
                    }
                }else if(respond.type =='success'){ 
                    if(output_function){
                        $scope[output_function](respond);
                    }
                }else{
                    var title = respond.type;
                    var text = respond.message; 
                    showDialogInfo(null, title, text);
                    console.log("No data");
                }
                
                if(loading_element){
                    $timeout(function(){
                        $scope[loading_element].is_processing = false;
                    }, 10); 
                }
            },
            error: function (data) {
                console.log('An error occurred.');
                console.log(data);

                if(loading_element){
                    $timeout(function(){
                        $scope[loading_element].is_processing = false;
                    }, 10); 
                }
            } 
        }); 
    }

    /**
     * @param {*} form_action: string
     */
    function call_ajax_insert_data (form_action, form_data_obj, query_function, output_function){ 
        console.log(form_data_obj);
        var form_data_json = JSON.parse(form_data_obj);
        form_data_json.function =  query_function;

        angular.element.ajax({ 
            method      : 'POST', 
            url         : cyn_wp_ajax.ajax_url +'?action=' + form_action, 
            dataType    : 'json', 
            contentType: "application/x-www-form-urlencoded; charset=UTF-8", // $_POST 
            // data        : { formData : form_data_obj },  
            data        : { formData : form_data_json }, 
            cache       : false,
            beforeSend:function(){
                // $scope.register.is_adding = true; 
              },
            success  : function(respond){     
                console.log(respond); 
                if(respond.type == 'success'){  
                    var title = respond.type;
                    var text = respond.message; 
                    showDialogInfo(null, title, text);
                    if(output_function){
                        $scope[output_function](); 
                    }
                }else{ 
                    if(respond.data){
                        var title = respond.data.type;
                        var text = respond.data.message;
                    }
                    $scope.is_loading = false;  
                    showDialogInfo(null, title, text);
                }

                $scope.register.is_processing = false; 
            },
            error: function (data) { 
                $scope.register.is_adding = false; 
                $scope.is_loading = false;
                console.log('An error occurred.');
                console.log(data);
            }
        });
    } 


    /**
     * @param {*} form_action: string
     */
    function call_ajax_update_data (form_action, form_data_obj, query_function, output_function){ 
        form_data_obj.function =  query_function;
        angular.element.ajax({ 
            method      : 'POST', 
            url         : cyn_wp_ajax.ajax_url +'?action=' + form_action, 
            dataType    : 'json', 
            contentType: "application/x-www-form-urlencoded; charset=UTF-8", // $_POST 
            data        : { formData : form_data_obj }, 
            cache       : false,
            beforeSend:function(){
                // $scope.register.is_adding = true; 
              },
            success  : function(respond){     
                console.log(respond);  
                if(respond.type == 'success'){  
                    var title = respond.type;
                    var text = respond.message; 
                    showDialogInfo(null, title, text);
                    if(output_function){
                        $scope[output_function](); 
                    }
                }else{ 
                    if(respond.data){
                        var title = respond.data.type;
                        var text = respond.data.message;
                    } 
                    showDialogInfo(null, title, text);
                }
            },
            error: function (data) { 
                $scope.register.is_adding = false; 
                console.log('An error occurred.');
                console.log(data);
            }
        });
    } 

    

